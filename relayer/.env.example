# =============================================================================
# Accesly Relayer — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- Server ---
PORT=3001
# Secret key to authenticate requests from the SDK to the relayer
RELAYER_API_KEY=your_secret_api_key_here

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Cognito User Pool ID — used to validate JWT tokens from the SDK
# Found in: AWS Console → Cognito → User Pools → your pool → Pool ID
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxx

# --- Stellar ---
# "testnet" or "mainnet"
STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Default fund account — pays XLM fees on behalf of users (developer_pays strategy)
# This is Accesly's own fund account. Developers can configure their own in app_configs.
RELAYER_FUND_SECRET=S...your_fund_account_secret

# 32-byte hex key for encrypting channel account secrets in DynamoDB
ENCRYPTION_KEY=your_64_char_hex_key

# --- DynamoDB table names ---
DYNAMO_TABLE_RELAYER_TXS=relayer_transactions
DYNAMO_TABLE_USAGE=usage_tracking
DYNAMO_TABLE_SWAPS=fund_account_swaps
DYNAMO_TABLE_CHANNELS=channel_accounts

# --- Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- CloudWatch ---
# Set to "true" to enable pushing metrics to CloudWatch
CLOUDWATCH_ENABLED=false

# --- Monitor ---
# How often to poll Stellar for on-chain events (milliseconds)
MONITOR_POLL_INTERVAL_MS=30000

# --- Replenishment cron ---
# How often to check fund account balances (cron syntax)
REPLENISHMENT_CRON=*/5 * * * *

