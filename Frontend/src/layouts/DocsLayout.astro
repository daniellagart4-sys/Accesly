---
interface Props {
  title: string;
  description?: string;
  section?: string;
  pageId?: string;
}

const {
  title,
  description = 'Documentación técnica de Accesly. SDK, arquitectura, seguridad, API y guías para integradores.',
  section = '',
  pageId = ''
} = Astro.props;

const fullTitle = `${title} · Accesly Docs`;

