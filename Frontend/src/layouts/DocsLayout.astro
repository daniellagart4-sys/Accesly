19.5,27.3L20.1,27.0L20.6,26.7L21.1,26.4L21.7,26.2L22.3,25.9L23.0,25.6L23.6,25.3L24.2,25.1L24.7,24.8L25.2,24.5L25.6,24.2L25.9,24.0L26.3,23.7L26.6,23.4L26.9,23.1L27.1,22.9L27.3,22.6L27.5,22.3L27.6,22.0L27.7,21.8L27.8,21.5L27.9,21.2L28.0,20.9L28.0,20.7L28.1,20.4L28.1,20.1L28.1,19.8L28.0,19.6L28.0,19.3L27.9,19.0L27.9,18.7L27.8,18.4L27.7,18.2L27.6,17.9L27.4,17.6L27.3,17.3L27.2,17.1L27.1,16.8L27.0,16.5L26.8,16.2L26.6,16.0L26.4,15.7L26.2,15.4L25.9,15.1L25.7,14.9L25.2,14.6L24.7,14.3L23.9,14.0Z' fill='%230c0c0f'/%3E%3Ctext x='48' y='30' font-family='system-ui,-apple-system,sans-serif' font-weight='800' font-size='26' letter-spacing='-0.3' fill='%23fff'%3Eccesly%3C/text%3E%3C/svg%3E";

const nav = [
  {
    title: 'Empezar',
    items: [
      { id: 'index', label: 'Introducción', href: '/docs' },
      { id: 'overview', label: 'Qué es Accesly', href: '/docs/overview' },
      { id: 'quickstart', label: 'Quickstart', href: '/docs/quickstart' },
    ],
  },
  {
    title: 'Cómo funciona',
    items: [
      { id: 'architecture', label: 'Arquitectura', href: '/docs/architecture' },
      { id: 'security', label: 'Seguridad', href: '/docs/security' },
      { id: 'recovery', label: 'Recuperación', href: '/docs/recovery' },
      { id: 'networks', label: 'Redes', href: '/docs/networks' },
    ],
  },
  {
    title: 'SDK y API',
    items: [
      { id: 'sdk-reference', label: 'SDK Reference', href: '/docs/sdk-reference' },
      { id: 'api-reference', label: 'API Reference', href: '/docs/api-reference' },
      { id: 'errors', label: 'Errores', href: '/docs/errors' },
    ],
  },
  {
    title: 'Integraciones',
    items: [
      { id: 'kyc-fiat', label: 'KYC y fiat', href: '/docs/kyc-fiat' },
      { id: 'dashboard', label: 'Dashboard', href: '/docs/dashboard' },
    ],
  },
  {
    title: 'Recursos',
    items: [
      { id: 'changelog', label: 'Changelog', href: '/docs/changelog' },
    ],
  },
];
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- Top nav -->
    <nav class="docs-nav" role="navigation" aria-label="Main navigation">
      <div class="docs-nav-inner">
        <a href="/" class="docs-nav-logo" aria-label="Accesly home">
          <img src={logoSvg} alt="Accesly" width="120" height="32" />
        </a>
        <div class="docs-nav-links">
          <a href="/" class="docs-nav-link">Home</a>
          <a href="/docs" class="docs-nav-link active">Docs</a>
          <a href="/demo" class="docs-nav-link">Demo</a>
        </div>
        <div class="docs-nav-actions">
          <a href="https://dashboard-accesly.vercel.app/" class="btn btn-ghost" target="_blank" rel="noopener">Dashboard</a>
          <a href="https://github.com/Accesly" class="btn btn-primary" target="_blank" rel="noopener">GitHub</a>
        </div>
        <button class="docs-nav-mobile-toggle" type="button" aria-label="Toggle sidebar" aria-expanded="false">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Docs shell -->
    <div class="docs-shell">

      <!-- Sidebar -->
      <aside class="docs-sidebar" id="docsSidebar">
        <nav aria-label="Docs navigation">
          {nav.map(group => (
            <div class="sidebar-group">
              <div class="sidebar-group-title">{group.title}</div>
              <ul class="sidebar-list">
                {group.items.map(item => (
                  <li>
                    <a
                      href={item.href}
                      class={`sidebar-link ${pageId === item.id ? 'active' : ''}`}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <!-- Content -->
      <main class="docs-content">
        {section && <div class="docs-breadcrumb">{section}</div>}
        <slot />

        <footer class="docs-footer">
          <div class="docs-footer-inner">
            <div>
              <span class="docs-footer-brand">Accesly</span>
              <span class="docs-footer-tag">Non custodial Stellar wallet infrastructure</span>
            </div>
            <div class="docs-footer-links">
              <a href="/">Home</a>
              <a href="/demo">Demo</a>
              <a href="https://dashboard-accesly.vercel.app/" target="_blank" rel="noopener">Dashboard</a>
              <a href="https://github.com/Accesly" target="_blank" rel="noopener">GitHub</a>
            </div>
          </div>
        </footer>
      </main>

    </div>

    <script>
      const toggle = document.querySelector('.docs-nav-mobile-toggle');
      const sidebar = document.getElementById('docsSidebar');
      if (toggle && sidebar) {
        toggle.addEventListener('click', () => {
          const open = sidebar.classList.toggle('open');
          toggle.setAttribute('aria-expanded', String(open));
        });
      }
    </script>

    <style is:global>
      :root {
        --bg: #0c0c0f;
        --bg2: #141418;
        --bg3: #1c1c22;
        --bg4: #26262e;
        --lav: #a78bfa;
        --lav2: #c4b5fd;
        --lavD: #7c3aed;
        --lavDD: #6d28d9;
        --mint: #34d399;
        --mint2: #6ee7b7;
        --mintD: #059669;
        --tx: #f4f4f5;
        --tx2: #a1a1aa;
        --tx3: #71717a;
        --border: rgba(255, 255, 255, 0.06);
        --border2: rgba(255, 255, 255, 0.12);
        --glass: rgba(255, 255, 255, 0.03);
        --r: 16px;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'DM Sans', sans-serif;
        color: var(--tx);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
      }
      a { text-decoration: none; color: inherit; }
      button { font-family: inherit; cursor: pointer; border: none; }
      ::selection { background: var(--lavD); color: #fff; }
      a:focus-visible, button:focus-visible {
        outline: 2px solid var(--lav);
        outline-offset: 3px;
        border-radius: 4px;
      }
      ::-webkit-scrollbar { width: 8px; height: 8px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--bg4); border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--border2); }

      /* Button variants (mirror del landing) */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 600;
        border-radius: 10px;
        padding: 10px 20px;
        transition: all 0.2s;
        white-space: nowrap;
      }
      .btn-primary {
        background: var(--lav);
        color: #0c0c0f;
      }
      .btn-primary:hover { background: var(--lav2); transform: translateY(-1px); }
      .btn-ghost {
        background: transparent;
        color: var(--tx2);
        border: 1px solid var(--border);
      }
      .btn-ghost:hover {
        color: var(--tx);
        border-color: var(--border2);
        background: var(--glass);
      }
      .btn-outline {
        background: transparent;
        color: var(--tx);
        border: 1px solid var(--border);
      }
      .btn-outline:hover {
        border-color: var(--lav);
        color: var(--lav);
        background: rgba(167, 139, 250, 0.05);
      }
      .btn-lg { padding: 14px 28px; font-size: 15px; border-radius: 12px; }

      /* Gradient text */
      .grad-text {
        background: linear-gradient(135deg, var(--lav), var(--mint));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* ==============================
         Docs top nav
         ============================== */
      .docs-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        padding: 0 24px;
        background: rgba(12, 12, 15, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
      }
      .docs-nav-inner {
        max-width: 1360px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .docs-nav-logo img { height: 28px; width: auto; }
      .docs-nav-links { display: flex; gap: 28px; }
      .docs-nav-link {
        font-size: 14px;
        color: var(--tx2);
        font-weight: 500;
        transition: color 0.2s;
      }
      .docs-nav-link:hover, .docs-nav-link.active { color: var(--tx); }
      .docs-nav-link.active {
        position: relative;
      }
      .docs-nav-link.active::after {
        content: '';
        position: absolute;
        bottom: -22px;
        left: 0; right: 0;
        height: 2px;
        background: var(--lav);
        border-radius: 2px;
      }
      .docs-nav-actions { display: flex; gap: 10px; align-items: center; }
      .docs-nav-mobile-toggle {
        display: none;
        background: none;
        color: var(--tx);
        padding: 4px;
      }

      /* ==============================
         Docs shell (sidebar + content)
         ============================== */
      .docs-shell {
        display: grid;
        grid-template-columns: 260px 1fr;
        max-width: 1360px;
        margin: 0 auto;
        padding-top: 64px;
        min-height: 100vh;
      }
      .docs-sidebar {
        position: sticky;
        top: 64px;
        height: calc(100vh - 64px);
        overflow-y: auto;
        padding: 32px 24px 40px;
        border-right: 1px solid var(--border);
      }
      .sidebar-group { margin-bottom: 24px; }
      .sidebar-group-title {
        font-size: 11px;
        font-weight: 600;
        color: var(--tx3);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 8px;
        padding: 0 8px;
      }
      .sidebar-list { list-style: none; display: flex; flex-direction: column; gap: 2px; }
      .sidebar-link {
        display: block;
        padding: 7px 12px;
        border-radius: 8px;
        font-size: 14px;
        color: var(--tx2);
        transition: all 0.15s;
      }
      .sidebar-link:hover {
        color: var(--tx);
        background: var(--glass);
      }
      .sidebar-link.active {
        color: var(--lav);
        background: rgba(167, 139, 250, 0.08);
        font-weight: 500;
      }

      /* ==============================
         Content area
         ============================== */
      .docs-content {
        padding: 48px 56px 80px;
        max-width: 880px;
        min-width: 0;
      }
      .docs-breadcrumb {
        font-size: 12px;
        color: var(--lav);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 600;
        margin-bottom: 16px;
      }
      .docs-content h1 {
        font-family: 'Sora', sans-serif;
        font-size: clamp(30px, 4vw, 42px);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.15;
        margin-bottom: 20px;
      }
      .docs-content h2 {
        font-family: 'Sora', sans-serif;
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.01em;
        margin: 56px 0 16px;
        padding-top: 8px;
      }
      .docs-content h3 {
        font-family: 'Sora', sans-serif;
        font-size: 18px;
        font-weight: 600;
        margin: 36px 0 12px;
      }
      .docs-content .lead {
        font-size: 18px;
        color: var(--tx2);
        line-height: 1.6;
        margin-bottom: 32px;
      }
      .docs-content p {
        font-size: 15.5px;
        color: var(--tx2);
        line-height: 1.7;
        margin-bottom: 16px;
      }
      .docs-content a {
        color: var(--lav);
        border-bottom: 1px solid rgba(167, 139, 250, 0.3);
        transition: border-color 0.15s;
      }
      .docs-content a:hover { border-bottom-color: var(--lav); }
      .docs-content strong { color: var(--tx); font-weight: 600; }
      .docs-content ul, .docs-content ol {
        padding-left: 22px;
        margin-bottom: 20px;
      }
      .docs-content li {
        font-size: 15.5px;
        color: var(--tx2);
        line-height: 1.7;
        margin-bottom: 8px;
      }
      .docs-content li::marker { color: var(--tx3); }
      .docs-content code {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13.5px;
        background: var(--bg3);
        color: var(--lav2);
        padding: 2px 6px;
        border-radius: 4px;
        border: 1px solid var(--border);
      }
      .docs-content pre {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px 22px;
        margin: 20px 0 24px;
        overflow-x: auto;
        font-size: 13.5px;
        line-height: 1.6;
      }
      .docs-content pre code {
        background: transparent;
        border: none;
        padding: 0;
        color: var(--tx);
        font-family: 'JetBrains Mono', monospace;
      }
      .docs-content pre .k { color: var(--lav); }
      .docs-content pre .s { color: var(--mint2); }
      .docs-content pre .c { color: var(--tx3); font-style: italic; }
      .docs-content pre .n { color: #fbbf24; }
      .docs-content pre .f { color: #60a5fa; }

      /* Callouts */
      .callout {
        border-radius: 12px;
        padding: 16px 20px;
        margin: 24px 0;
        display: flex;
        gap: 14px;
        align-items: flex-start;
      }
      .callout-icon {
        flex-shrink: 0;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        margin-top: 2px;
      }
      .callout-body { flex: 1; min-width: 0; }
      .callout-body p:last-child { margin-bottom: 0; }
      .callout-title {
        font-family: 'Sora', sans-serif;
        font-weight: 600;
        color: var(--tx);
        font-size: 14px;
        margin-bottom: 4px;
      }
      .callout-info {
        background: rgba(96, 165, 250, 0.06);
        border: 1px solid rgba(96, 165, 250, 0.15);
      }
      .callout-info .callout-icon {
        background: rgba(96, 165, 250, 0.2);
        color: #60a5fa;
      }
      .callout-warn {
        background: rgba(251, 191, 36, 0.06);
        border: 1px solid rgba(251, 191, 36, 0.18);
      }
      .callout-warn .callout-icon {
        background: rgba(251, 191, 36, 0.2);
        color: #fbbf24;
      }
      .callout-danger {
        background: rgba(248, 113, 113, 0.06);
        border: 1px solid rgba(248, 113, 113, 0.18);
      }
      .callout-danger .callout-icon {
        background: rgba(248, 113, 113, 0.2);
        color: #f87171;
      }
      .callout-good {
        background: rgba(52, 211, 153, 0.06);
        border: 1px solid rgba(52, 211, 153, 0.18);
      }
      .callout-good .callout-icon {
        background: rgba(52, 211, 153, 0.2);
        color: var(--mint);
      }

      /* Cards para docs index */
      .doc-cards {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
        margin: 28px 0;
      }
      .doc-card {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 22px 24px;
        transition: all 0.2s;
        display: block;
      }
      .doc-card:hover {
        border-color: rgba(167, 139, 250, 0.3);
        transform: translateY(-2px);
        background: var(--bg3);
      }
      .doc-card {
        border-bottom: 1px solid var(--border);
      }
      .doc-card:hover { border-bottom-color: rgba(167, 139, 250, 0.3); }
      .doc-card-tag {
        font-size: 11px;
        color: var(--lav);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 600;
        margin-bottom: 8px;
      }
      .doc-card-title {
        font-family: 'Sora', sans-serif;
        font-size: 17px;
        font-weight: 600;
        color: var(--tx);
        margin-bottom: 6px;
      }
      .doc-card-text {
        font-size: 13.5px;
        color: var(--tx2);
        line-height: 1.55;
        margin: 0;
      }

      /* Definition table (for reference lists) */
      .def-table {
        width: 100%;
        border-collapse: collapse;
        margin: 20px 0 24px;
        font-size: 14px;
      }
      .def-table th, .def-table td {
        padding: 12px 14px;
        text-align: left;
        border-bottom: 1px solid var(--border);
      }
      .def-table th {
        color: var(--tx3);
        font-weight: 600;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        background: var(--bg2);
      }
      .def-table td { color: var(--tx2); }
      .def-table td code { font-size: 12.5px; }
      .def-table tr:last-child td { border-bottom: none; }

      /* Step list */
      .step-list {
        list-style: none;
        padding: 0;
        counter-reset: step;
      }
      .step-list > li {
        counter-increment: step;
        padding-left: 46px;
        position: relative;
        margin-bottom: 20px;
      }
      .step-list > li::before {
        content: counter(step);
        position: absolute;
        left: 0;
        top: 0;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: rgba(167, 139, 250, 0.1);
        color: var(--lav);
        border: 1px solid rgba(167, 139, 250, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 13px;
      }

      /* Footer */
      .docs-footer {
        margin-top: 96px;
        padding-top: 32px;
        border-top: 1px solid var(--border);
      }
      .docs-footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
      }
      .docs-footer-brand {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        color: var(--tx);
        margin-right: 12px;
      }
      .docs-footer-tag {
        font-size: 13px;
        color: var(--tx3);
      }
      .docs-footer-links { display: flex; gap: 22px; }
      .docs-footer-links a {
        font-size: 13px;
        color: var(--tx2);
      }
      .docs-footer-links a:hover { color: var(--tx); }

      /* Mobile */
      @media (max-width: 900px) {
        .docs-nav-links { display: none; }
        .docs-nav-mobile-toggle { display: inline-flex; }
        .docs-shell { grid-template-columns: 1fr; }
        .docs-sidebar {
          position: fixed;
          top: 64px;
          left: 0;
          width: 280px;
          height: calc(100vh - 64px);
          background: var(--bg);
          border-right: 1px solid var(--border);
          transform: translateX(-100%);
          transition: transform 0.25s ease;
          z-index: 90;
        }
        .docs-sidebar.open { transform: translateX(0); }
        .docs-content { padding: 32px 24px 60px; }
      }

      @media (prefers-reduced-motion: reduce) {
        * { animation: none !important; transition: none !important; }
      }
    </style>
  </body>
</html>
